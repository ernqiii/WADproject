<!DOCTYPE html>
<html>
<head>
  <title>Interest Requests</title>
</head>
<body>

<h1>Interest Requests for Your Listings</h1>
<hr>

<% if (requestArray.length > 0) { %>
  <% requestArray.forEach(item => { %>
    <div>
      <p><strong>Listing:</strong> <%= item.listing.title %></p>
      <p><strong>Price:</strong> $<%= item.listing.price %></p>
      <p><strong>Interested User Name:</strong> <%= item.request.name %></p>
      <p><strong>Email:</strong> <%= item.request.email %></p>
      <p><strong>Phone:</strong> <%= item.request.phone %></p>
      <p><strong>Message:</strong> <%= item.request.message %></p>
      <hr>
    </div>
  <% }) %>
<% } else { %>
  <h3>No interest requests yet</h3>
<% } %>

<form action="/" method="GET">
  <button type="submit">Back to Home</button>
</form>

</body>
</html>