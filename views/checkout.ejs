<!DOCTYPE html>
<html>
<head>
  <title>Checkout</title>
</head>
<body>

<h1>Checkout</h1>
<hr>

<h3><%= listing.title %></h3>

  <p><strong>Type:</strong> <%= listing.room_type %></p>
  <p><strong>Region:</strong> <%= listing.region %></p>
  <p><strong>Location:</strong> <%= listing.location %></p>
  <p><strong>Gender:</strong> <%= listing.gender %></p> 
  <p><strong>Roommates:</strong> <%= listing.roommates %></p> 
  <p><strong>Price:</strong> $<%= listing.price %>/month</p>
  <p>
    <strong>Amenities:</strong>
    <% if (listing.amenities && listing.amenities.length > 0) { %>
      <%= listing.amenities.join(", ") %>
    <% } else { %>
      None
    <% } %>
  </p>

  <p><strong>Description:</strong> <%= listing.description %></p>
</div>
<hr>




<form action="/wishlist/checkout/submit" method="POST">
  <input type="hidden" name="listingId" value="<%= listing._id %>">

  




<%# But if message was never defined at all, JavaScript errors before it can even evaluate ||. %>
<br>
  Name:
  <input type="text" name="name" value="<%= name || '' %>" required> 
  <br><br>
  
  <p><u><strong>Please fill in at least one contact method</u></strong></p>
  
  Email:
  <input type="email" name="email" value="<%= email || '' %>">
  <br><br>

  Phone:(via messages,whatsapp or phone calls)
  <input type="text" name="phone" value="<%= phone || '' %>">
  <br><br>

  Telegram:
  <input type="text" name="telegram" value="<%= telegram || '' %>">
  <br><br>

  Preferred Contact Method<strong>(this contact information has to be provided)</strong>:
  <br>
  <select name="contact_method">
    <option value="">--Please Select One--</option>
    <option value="email" <%= contact_method === "email" ? "selected" : "" %>>Email</option>
    <option value="phone" <%= contact_method === "phone" ? "selected" : "" %>>Phone</option>
    <option value="telegram" <%= contact_method === "telegram" ? "selected" : "" %>>Telegram</option>
    <option value="whatsapp" <%= contact_method === "whatsapp" ? "selected" : "" %>>Whatsapp</option>
  </select>
  <br><br>
  Message:
  <textarea name="message" placeholder="Send a Message" ><%= message || '' %></textarea><%# the data rention not within the text area  part %>
  <br><br>
  <p>
    <small>
      By submitting this form, you agree that your contact details and message
      will be stored for the purpose of managing your interest in this listing.
      Your submission will be shown in your profile, and you may edit or delete it later.
    </small>
  </p>
 
  <input type="checkbox" name="consent" required>
    I understand that my submitted contact details and message will be stored for this interest request.
  <br><br>

  <button type="submit">Submit Request</button>
</form>
<% if (error){ %>
  <strong><%= error  %></strong>
<% } %>

</body>
</html>
