<!DOCTYPE html>
<html>
<head>
    <title>Explore Rooms</title>
</head>
<body>
    <h1>Student Housing</h1>
    <hr>

    <h3>Filters</h3>

    <label>Search:</label>
    <input type="text" id="search" placeholder="Search listings...">

    <label>Region:</label>
    <select id="region">
        <option value="">All Regions</option>
        <option value="North">North</option>
        <option value="South">South</option>
        <option value="East">East</option>
        <option value="West">West</option>
        <option value="Central">Central</option>
        <option value="Northeast">Northeast</option>
        <option value="Northwest">Northwest</option>
        <option value="Southeast">Southeast</option>
        <option value="Southwest">Southwest</option>
    </select>

    <label>Type:</label>
    <select id="type">
        <option value="">All</option>
        <option value="Shared Room">Shared Room</option>
        <option value="Private Room">Private Room</option>
    </select>

    <label>Gender:</label>
    <select id="gender">
        <option value="">All</option>
        <option value="Male">Male</option>
        <option value="Female">Female</option>
    </select>

    <label>Max Price:</label>
    <input type="number" id="price" placeholder="Max price">

    <button onclick="showListings()">Search</button>
    <button onclick="resetFilters()">Reset Filters</button>

    <hr>
    <div id="listings"></div>

    <script>

        const data = <%- JSON.stringify(listings) %>;

        // Show listings when page loads
        showListings();

        // Display listings
        function showListings() {
            let searchFilter = document.getElementById('search').value.toLowerCase();
            let regionFilter = document.getElementById('region').value;
            let typeFilter = document.getElementById('type').value;
            let genderFilter = document.getElementById('gender').value;
            let priceFilter = document.getElementById('price').value;
            let container = document.getElementById('listings');
            let html = '';
            let count = 0;

            // Loop through each listing
            for (let i = 0; i < data.length; i++) {
                let listing = data[i];
                let listingId = listing._id || listing.id || i;

                // Check search filter
                if (searchFilter && !listing.title.toLowerCase().includes(searchFilter) && !listing.description.toLowerCase().includes(searchFilter)) {
                    continue;
                }

                // Check region filter
                if (regionFilter && listing.location !== regionFilter) continue;

                // Check type filter
                if (typeFilter && listing.type !== typeFilter) continue;

                // Check gender filter
                if (genderFilter && listing.gender !== genderFilter) continue;

                // Check price filter
                if (priceFilter && listing.price > priceFilter) continue;

                count++;

                let likeCount = listing.likes ? listing.likes.length : 0;
                let comments = listing.comments || [];

                // Build HTML for this listing
                html += '<hr>';
                html += '<h3>' + listing.title + '</h3>';
                html += '<p><strong>Type:</strong> ' + listing.type + '</p>';
                html += '<p><strong>Region:</strong> ' + listing.location + '</p>';
                if (listing.specificLocation) {
                    html += '<p><strong>Location:</strong> ' + listing.specificLocation + '</p>';
                }
                html += '<p><strong>Gender:</strong> ' + listing.gender + '</p>';
                html += '<p><strong>Price:</strong> $' + listing.price + '/month</p>';

                // Display amenities
                if (listing.amenities && listing.amenities.length > 0) {
                    html += '<p><strong>Amenities:</strong> ';
                    for (let j = 0; j < listing.amenities.length; j++) {
                        html += listing.amenities[j];
                        if (j != listing.amenities.length - 1)
                            html += ', ';
                    }
                    html += '</p>';
                }

                // Display description
                html += '<p><strong>Description:</strong> ' + listing.description + '</p>';

                // Action buttons
                html += '<p>';
                html += '<button id="like-btn-' + listingId + '" onclick="like(\'' + listingId + '\')"> Like (<span id="like-count-' + listingId + '">' + likeCount + '</span>)</button> ';
                html += '<button onclick="toggleComments(\'' + listingId + '\')"> Comments (' + comments.length + ')</button> ';
                html += '<button onclick="wishlist(\'' + listingId + '\')"> Wishlist</button>';
                html += '</p>';

                // Comments section (hidden by default)
                html += '<div id="comments-' + listingId + '" style="display:none; margin-left: 20px;">';
                if (comments.length > 0) {
                    for (let k = 0; k < comments.length; k++) {
                        let userName = comments[k].user?.name || comments[k].user || 'Anonymous';
                        html += '<p><strong>' + userName + ':</strong> ' + comments[k].text + '</p>';
                    }
                } else {
                    html += '<p>No comments yet.</p>';
                }
                html += '</div>';
            }

            if (count === 0) {
                html = '<p>No listings found matching your criteria.</p>';
            } else {
                html = '<p><strong>Found ' + count + ' listing' + (count !== 1 ? 's' : '') + '</strong></p>' + html;
            }

            container.innerHTML = html;
        }

        // Reset all filters
        function resetFilters() {
            document.getElementById('search').value = '';
            document.getElementById('region').value = '';
            document.getElementById('type').value = '';
            document.getElementById('gender').value = '';
            document.getElementById('price').value = '';
            showListings();
        }

        // Like a listing
        function like(id) {
            fetch('/explore/listings/' + id + '/like', { method: 'POST' })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    document.getElementById('like-count-' + id).textContent = result.likeCount;
                } else {
                    alert(result.message || 'Failed to like listing');
                }
            })
            .catch(err => {
                console.error(err);
                alert('Error liking listing');
            });
        }

        // Toggle comments visibility
        function toggleComments(id) {
            let commentsDiv = document.getElementById('comments-' + id);
            if (commentsDiv.style.display === 'none') {
                commentsDiv.style.display = 'block';
            } else {
                commentsDiv.style.display = 'none';
            }
        }

        // Add to wishlist
        function wishlist(id) {
            fetch('/wishlist/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ listingId: id })
            })
            .then(res => {
                if (res.redirected) {
                    window.location.href = res.url;
                } else {
                    alert('Added to wishlist!');
                }
            })
            .catch(err => {
                console.error(err);
                alert('Error adding to wishlist');
            });
        }
    </script>
</body>
</html>
