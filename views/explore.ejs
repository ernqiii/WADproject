        // End of change this later to mongodb data

        // Show listings when page loads
        showListings();

        // Display listings
        function showListings() {
            let searchFilter = document.getElementById('search').value.toLowerCase();
            let regionFilter = document.getElementById('region').value;
            let typeFilter = document.getElementById('type').value;
            let genderFilter = document.getElementById('gender').value;
            let priceFilter = document.getElementById('price').value;
            let container = document.getElementById('listings');
            let html = '';
            let count = 0;

            // Loop through each listing
            for (let i = 0; i < data.length; i++) {
                let listing = data[i];
                
                // Check search filter
                if (searchFilter && !listing.title.toLowerCase().includes(searchFilter) && !listing.description.toLowerCase().includes(searchFilter)) {
                    continue;
                }
                
                // Check region filter
                if (regionFilter && listing.location !== regionFilter) continue;

                // Check type filter
                if (typeFilter && listing.type !== typeFilter) continue;
                
                // Check gender filter
                if (genderFilter && listing.gender !== genderFilter) continue;
                
                // Check price filter
                if (priceFilter && listing.price > priceFilter) continue;

                count++;

                // Build HTML for this listing
                html += '<hr>';
                html += '<h3>' + listing.title + '</h3>';
                html += '<p><strong>Type:</strong> ' + listing.type + '</p>';
                html += '<p><strong>Region:</strong> ' + listing.location + '</p>';
                if (listing.specificLocation) {
                    html += '<p><strong>Location:</strong> ' + listing.specificLocation + '</p>';
                }
                html += '<p><strong>Gender:</strong> ' + listing.gender + '</p>';
                html += '<p><strong>Price:</strong> $' + listing.price + '/month</p>';
                
                // Display amenities
                if (listing.amenities && listing.amenities.length > 0) {
                    html += '<p><strong>Amenities:</strong> ';
                    for (let j = 0; j < listing.amenities.length; j++) {
                        html += listing.amenities[j];
                        if (j != listing.amenities.length - 1)
                            html += ', ';
                    }
                }
                
                // Display description
                html += '<p><strong>Description:</strong> ' + listing.description + '</p>';
                
                // Image placeholder (commented for future)
                // html += '<!-- <img src="' + listing.image + '" alt="' + listing.title + '"> -->';
                
                // Display comments
                if (listing.comments && listing.comments.length > 0) {
                    html += '<p><strong>Comments (' + listing.comments.length + '):</strong></p>';
                    for (let k = 0; k < listing.comments.length; k++) {
                        html += '<p>&nbsp;&nbsp;<strong>' + listing.comments[k].user + ':</strong> ' + listing.comments[k].text + '</p>';
                    }
                }

                // Action buttons
                html += '<p>';
                html += '<button onclick="like(' + listing.id + ')"> Like (' + listing.interested + ')</button> ';
                html += '<button onclick="toggleComments(' + listing.id + ')"> Comments (' + listing.comments.length + ')</button> ';
                html += '<button onclick="wishlist(' + listing.id + ')"> Wishlist</button>';
                html += '</p>';
            }

            if (count === 0) {
                html = '<p>No listings found matching your criteria.</p>';
            } else {
                html = '<p><strong>Found ' + count + ' listing' + (count !== 1 ? 's' : '') + '</strong></p>' + html;
            }

            container.innerHTML = html;
        }

        // Reset all filters
        function resetFilters() {
            document.getElementById('search').value = '';
            document.getElementById('region').value = '';
            document.getElementById('type').value = '';
            document.getElementById('gender').value = '';
            document.getElementById('price').value = '';
            showListings();
        }

        // Like a listing
        function like(id) {
            alert('You liked listing ' + id);
            // TODO: Send to MongoDB
            // fetch('/api/listings/' + id + '/like', {method: 'POST'})
        }

        // Toggle comments visibility
        function toggleComments(id) {
            let listing = data.find(l => l.id === id);
            if (!listing || !listing.comments.length) return;
            let msg = listing.comments.map(c => c.user + ': ' + c.text).join('\n');
            alert(msg);
        }

        // Add to wishlist
        function wishlist(id) {
            fetch('/wishlist/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ listingId: id })
            })
            .then(res => {
                if (res.redirected) {
                    window.location.href = res.url;
                } else {
                    alert('Added to wishlist!');
                }
            })
            .catch(err => {
                console.error(err);
                alert('Error adding to wishlist');
            });
        }
    </script>
