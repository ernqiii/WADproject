<!DOCTYPE html>
<html>
<head>
    <title>Explore Rooms</title>
</head>
<body>

    <h1>Student Housing</h1>

   
    <% if (user) { %>
        <p>
            Hello, <strong><%= user.username %></strong> |
            <a href="/profile">Go to Profile</a>
        </p>
    <% } %>

    <hr>

    <h3>Filters</h3>

    <label>Search:</label>
    <input type="text" id="search" placeholder="Search listings...">

    <label>Region:</label>
    <select id="region">
        <option value="">All Regions</option>
        <option value="North">North</option>
        <option value="South">South</option>
        <option value="East">East</option>
        <option value="West">West</option>
        <option value="Central">Central</option>
        <option value="Northeast">Northeast</option>
        <option value="Northwest">Northwest</option>
        <option value="Southeast">Southeast</option>
        <option value="Southwest">Southwest</option>
    </select>

    <label>Type:</label>
    <select id="type">
        <option value="">All</option>
        <option value="Shared Room">Shared Room</option>
        <option value="Private Room">Private Room</option>
    </select>

    <label>Gender:</label>
    <select id="gender">
        <option value="">All</option>
        <option value="Male">Male</option>
        <option value="Female">Female</option>
    </select>

    <label>Max Price:</label>
    <input type="number" id="price" placeholder="Max price">

    <button onclick="showListings()">Search</button>
    <button onclick="resetFilters()">Reset Filters</button>

    <hr>
    <div id="listings"></div>

    <script>

        // Mock data
        const data = [
            {
                id: 1,
                type: 'room',
                title: 'Cozy Room in Central District',
                description: 'Close to MRT stations and amenities.',
                location: 'Central',
                gender: 'Any',
                price: 800,
                amenities: ['WiFi', 'Air Conditioning'],
                interested: 12,
                comments: 5,
                wishlist: 3
            },
            {
                id: 2,
                type: 'roommate',
                title: 'Female Roommate Wanted - East Coast',
                description: 'Spacious apartment near East Coast Park.',
                location: 'East',
                gender: 'Female',
                price: 950,
                amenities: ['WiFi', 'Gym', 'Pool'],
                interested: 8,
                comments: 3,
                wishlist: 5
            }
        ];

        // Load listings on start
        showListings();

        function showListings() {
            let searchFilter = document.getElementById('search').value.toLowerCase();
            let regionFilter = document.getElementById('region').value;
            let typeFilter = document.getElementById('type').value;
            let genderFilter = document.getElementById('gender').value;
            let priceFilter = document.getElementById('price').value;

            let container = document.getElementById('listings');
            let html = '';
            let count = 0;

            for (let i = 0; i < data.length; i++) {
                let listing = data[i];

                if (searchFilter && !listing.title.toLowerCase().includes(searchFilter)) continue;
                if (regionFilter && listing.location !== regionFilter) continue;
                if (typeFilter && listing.type !== typeFilter) continue;
                if (genderFilter && listing.gender !== genderFilter) continue;
                if (priceFilter && listing.price > priceFilter) continue;

                count++;

                html += '<hr>';
                html += '<h3>' + listing.title + '</h3>';
                html += '<p><strong>Region:</strong> ' + listing.location + '</p>';
                html += '<p><strong>Gender:</strong> ' + listing.gender + '</p>';
                html += '<p><strong>Price:</strong> $' + listing.price + '</p>';
                html += '<p><strong>Description:</strong> ' + listing.description + '</p>';

                html += '<p>';
                html += '<button>Like (' + listing.interested + ')</button> ';
                html += '<button>Comments (' + listing.comments + ')</button> ';
                html += '<button>Wishlist (' + listing.wishlist + ')</button>';
                html += '</p>';

                // Comments section (hidden by default)
                html += '<div id="comments-' + listingId + '" style="display:none; margin-left: 20px;">';
                if (comments.length > 0) {
                    for (let k = 0; k < comments.length; k++) {
                        let userName = comments[k].user?.name || comments[k].user || 'Anonymous';
                        html += '<p><strong>' + userName + ':</strong> ' + comments[k].text + '</p>';
                    }
                } else {
                    html += '<p>No comments yet.</p>';
                }
                html += '</div>';
            }

            if (count === 0) {
                html = '<p>No listings found.</p>';
            }

            container.innerHTML = html;
        }

        function resetFilters() {
            document.getElementById('search').value = '';
            document.getElementById('region').value = '';
            document.getElementById('type').value = '';
            document.getElementById('gender').value = '';
            document.getElementById('price').value = '';
            showListings();
        }

    </script>

</body>
</html>
