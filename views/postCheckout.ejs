<!DOCTYPE html>
<html>
<head>
  <title>Interest Submitted</title>
</head>
<body bgcolor="#f7f4ef">
<center>
  <br>
  <font face="Georgia, serif" size="6" color="#3a3a3a"><b>🏠 Roommie Finder</b></font>
  <br><br>

  <table border="0" cellpadding="28" cellspacing="0" bgcolor="#ffffff" width="480">
    <tr>
      <td align="center">
        <font face="Arial, sans-serif" size="6" color="#27ae60">✓</font>
        <br>
        <font face="Georgia, serif" size="5" color="#3a3a3a"><b>Interest Submitted Successfully</b></font>
        <br><br>

        <hr color="#eeeeee" size="1" width="80%">
        <br>

        <font face="Arial, sans-serif" size="3" color="#555555">
          Your interest for <b>"<%= listing.title %>"</b> has been submitted.
        </font>
        <br>
        <font face="Arial, sans-serif" size="3" color="#777777">
          The landlord will be able to view your request in the system.
        </font>
        <br><br>

        <hr color="#eeeeee" size="1" width="80%">
        <br>

        <font face="Georgia, serif" size="4" color="#3a3a3a"><b>What would you like to do next?</b></font>
        <br><br>

        <table border="0" cellpadding="0" cellspacing="8">
          <tr>
            <td>
              <form action="/explore" method="GET">
                <table border="0" cellpadding="10" bgcolor="#c0392b">
                  <tr>
                    <td align="center">
                      <input type="submit" value="Explore Listings" style="background:transparent;border:none;color:#ffffff;font-size:13px;cursor:pointer;font-weight:bold;">
                    </td>
                  </tr>
                </table>
              </form>
            </td>
            <td>
              <form action="/wishlist" method="GET">
                <table border="0" cellpadding="10" bgcolor="#888888">
                  <tr>
                    <td align="center">
                      <input type="submit" value="Back to Wishlist" style="background:transparent;border:none;color:#ffffff;font-size:13px;cursor:pointer;font-weight:bold;">
                    </td>
                  </tr>
                </table>
              </form>
            </td>
            <td>
              <form action="/interest/submitted" method="GET">
                <table border="0" cellpadding="10" bgcolor="#555555">
                  <tr>
                    <td align="center">
                      <input type="submit" value="My Interest Forms" style="background:transparent;border:none;color:#ffffff;font-size:13px;cursor:pointer;font-weight:bold;">
                    </td>
                  </tr>
                </table>
              </form>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <br><br>
  <font face="Arial, sans-serif" size="2" color="#aaaaaa">&copy; 2026 Roommie Finder</font>
  <br><br>
</center>
</body>
</html>
