<!DOCTYPE html>
<html>
<head>
  <title>Landlord Requests</title>
</head>
<body>

  <h1>Incoming Interest Requests</h1>
  <hr>

  <form action="/interest/received" method="GET">
    <label for="status">Filter by status:</label>
    <select name="status" id="status">
      <option value="" <%= selectedStatus === "" ? "selected" : "" %>>All</option>
      <option value="Active" <%= selectedStatus === "Active" ? "selected" : "" %>>Active</option>
      <option value="Closed" <%= selectedStatus === "Closed" ? "selected" : "" %>>Closed</option>
    </select>
    <button type="submit">Filter</button>
  </form>

  <br>

  <% if (interestListingArray && interestListingArray.length > 0) { %>
    <% interestListingArray.forEach(function(item) { %>
      <hr>

      <h3><%= item.listing ? item.listing.title : "Listing deleted" %></h3>

      <% if (item.listing) { %>
        <p><strong>Location:</strong> <%= item.listing.location %></p>
        <p><strong>Price:</strong> $<%= item.listing.price %>/month</p>
        <% if (item.listing.photos && item.listing.photos.length > 0) { %>
            <% item.listing.photos.forEach(function(photo) { %>
                <img src="data:<%= photo.contentType %>;base64,<%= photo.data.toString('base64') %>" width="250" height="250" alt="listing photo">
            <% }); %>
   
             
        <% } else { %>
          <p>No image available</p>
        <% } %>
      <% } %>

      <p><strong>Name:</strong> <%= item.interest.name %></p>
      <p><strong>Gender:</strong> <%= item.interest.gender %></p>
      <p><strong>Email:</strong> <%= item.interest.email || "Not provided" %></p>
      <p><strong>Phone:</strong> <%= item.interest.phone || "Not provided" %></p>
      <p><strong>Telegram:</strong> <%= item.interest.telegram || "Not provided" %></p>
      <p><strong>Preferred Contact Method:</strong> <%= item.interest.preferredContactMethod %></p>
      <p><strong>Message:</strong> <%= item.interest.message || "No message" %></p>
      <p><strong>Status:</strong> <%= item.interest.status %></p>

      <% if (item.interest.createdAt) { %>
        <p><strong>Submitted On:</strong> <%= item.interest.createdAt.toDateString() %></p>
      <% } %>

      <form action="/interest/received/update-status" method="POST">
        <input type="hidden" name="interestId" value="<%= item.interest._id %>">

        <label>Update Status:</label>
        <select name="status">
          <option value="Active" <%= item.interest.status === "Active" ? "selected" : "" %>>Active</option>
          <option value="Closed" <%= item.interest.status === "Closed" ? "selected" : "" %>>Closed</option>
        </select>

        <button type="submit">Save Status</button>
      </form>

    <% }) %>
  <% } else { %>
    <p>No interest requests found.</p>
  <% } %>
  <hr>
  <a href="/interest">Go back to view Interests Forms</a>

</body>
</html>