<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title><%= user.username %>'s Profile</title>
</head>
<body>

    <table width="100%">
        <tr>
            <td>
                <h1><%= user.username %>'s Profile</h1>
            </td>

            <td align="right">
                <form method="POST" action="/profile/search">
                    <label>Search by username:</label>
                    <input type="text" name="username" placeholder="Enter username" required>
                    <button type="submit">Search</button>
                </form>
            </td>
        </tr>
    </table>

    <% if (loggedInUserRole === 'admin' && String(user._id) !== String(loggedInUserId)) { %>
        <p><a href="/admin-profile">Back to Admin</a></p>
    <% } else if (String(user._id) === String(loggedInUserId)) { %>
        <p>
            <a href="/explore">Back to Explore</a> |
            <a href="/wishlist">Wishlist</a> |
            <a href="/listing/new">New Listing</a> |
            <a href="/interest">Interest Forms</a>
        </p>
    <% } else { %>
        <p>
            <a href="/explore">Back to Explore</a> |
            <a href="/profile">My Profile</a>
        </p>
    <% } %>

    <hr>

    <h2>Profile Information</h2>

    <% if (profileImage) { %>
        <p>
            <img src="<%= profileImage %>" alt="Profile Picture" width="150" height="150">
        </p>
    <% } else { %>
        <p>No profile picture uploaded.</p>
    <% } %>

    <p><strong>Username:</strong> <%= user.username %></p>
    <p><strong>Full Name:</strong> <%= user.fullName %></p>
    <p><strong>Email:</strong> <%= user.email %></p>
    <p><strong>Gender:</strong> <%= user.gender %></p>
    <p><strong>Phone:</strong> <%= user.phone %></p>
    <p><strong>Bio:</strong> <%= user.bio %></p>

    <% if (loggedInUserRole === 'admin' && String(user._id) !== String(loggedInUserId)) { %>
        <p>
            <form action="/admin-profile/delete-user/<%= user._id %>" method="POST" style="display:inline;">
                <button type="submit" onclick="return confirm('Delete this user and all their data?');">Delete User</button>
            </form>
        </p>
    <% } else if (String(user._id) === String(loggedInUserId)) { %>
        <p>
            <a href="/profile/edit">Edit Profile</a>
            <form action="/profile/delete" method="POST" style="display:inline;">
                <button type="submit" onclick="return confirm('Are you sure you want to delete your account? This cannot be undone.');">Delete Account</button>
            </form>
        </p>
    <% } %>

    <hr>

    <h2>Listings</h2>

    <% if (listings.length === 0) { %>
        <p>No listings posted yet.</p>
    <% } else { %>
        <% listings.forEach(function(listing) { %>
      <p><strong><%= listing.title %></strong></p>

        <% if (listing.photos.length > 0) { %>
        <% listing.photos.forEach(function(photo) { %>
        <img src="data:<%= photo.contentType %>;base64,<%= photo.data.toString('base64') %>" alt="listing photo" width="250" height="250">
        <% }) %>
        <% } %>

      <p><strong>Region:</strong> <%= listing.region %></p>
      <p><strong>Price:</strong> $<%= listing.price %> / month</p>
      <br>
        <a href="/listing/<%= listing._id %>">View Details</a>
        
          <hr>
     <% }) %>
    <% } %>

    <u><h2>Reviews</h2></u>

    <p><strong>Average Rating:</strong> <%= avgRating ? (avgRating || 0).toFixed(1) : "0.0" %> / 5</p>
    <p><strong>Total Reviews:</strong> <%= totalReviews || 0 %></p>
    <hr>

    <% if (String(user._id) !== String(loggedInUserId)) { %>
        <h3>Leave a Review</h3>

        <form method="POST" action="/reviews/add">
            <input type="hidden" name="reviewedUserId" value="<%= user._id %>">

            <p>
                Rating:
                <select name="rating" required>
                    <option value="">Select</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                </select>
            </p>

            <p>
                Comment:<br>
                <textarea name="comment" rows="4" cols="40"></textarea>
            </p>

            <button type="submit">Submit Review</button>
        </form>

        <hr>
    <% } %>

    <% if (reviews.length === 0) { %>
        <p>No reviews yet.</p>
    <% } else { %>
        <% reviews.forEach(function(review) { %>
            <p>
                <strong>Reviewer:</strong>
                <% if (review.reviewerId) { %>
                    <a href="/profile/<%= review.reviewerId._id %>"><%= review.reviewerId.username %></a>
                <% } else { %>
                    Unknown User
                <% } %><br>

                <strong>Rating:</strong> <%= review.rating %> / 5<br>

                <strong>Comment:</strong>
                <%= review.comment && review.comment.trim() !== "" ? review.comment : "No comment provided." %>
            </p>

            <% if (review.reviewerId && String(review.reviewerId._id) === String(loggedInUserId)) { %>
                <p>
                    <a href="/reviews/edit?reviewId=<%= review._id %>">Edit Review</a>
                </p>

                <form method="POST" action="/reviews/delete">
                    <input type="hidden" name="reviewId" value="<%= review._id %>">
                    <input type="hidden" name="reviewedUserId" value="<%= user._id %>">
                    <button type="submit">Delete Review</button>
                </form>
            <% } %>

            <hr>
        <% }) %>
    <% } %>

</body>
</html>