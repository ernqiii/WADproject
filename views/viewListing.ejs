<!DOCTYPE html>
<html>
<head>
  <title><%= listing.title %></title>
</head>
<body bgcolor="#f7f4ef">
<center>
  <br>
  <font face="Georgia, serif" size="6" color="#3a3a3a"><b>🏠 Roommie Finder</b></font>
  <br>
  <font face="Arial, sans-serif" size="3">
    <a href="/profile/<%= listing.landlord %>"><font color="#c0392b">Back to Profile</font></a>
  </font>
  <br><br>

  <table border="0" cellpadding="24" cellspacing="0" bgcolor="#ffffff" width="660">
    <tr>
      <td>
        <font face="Georgia, serif" size="5" color="#3a3a3a"><b><%= listing.title %></b></font>
        <br><br>

        <% if (listing.photos && listing.photos.length > 0) { %>
          <% listing.photos.forEach(function(photo) { %>
            <img src="data:<%= photo.contentType %>;base64,<%= photo.data.toString('base64') %>" width="220" height="220" alt="listing photo">
          <% }); %>
          <br><br>
        <% } %>

        <table border="0" cellpadding="5" cellspacing="0">
          <tr>
            <td width="160"><font face="Arial, sans-serif" size="3" color="#555555"><b>Region:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.region %></font></td>
          </tr>
          <tr>
            <td><font face="Arial, sans-serif" size="3" color="#555555"><b>Location:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.location %></font></td>
          </tr>
          <tr>
            <td><font face="Arial, sans-serif" size="3" color="#555555"><b>Price:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a">$<%= listing.price %>/month</font></td>
          </tr>
          <tr>
            <td><font face="Arial, sans-serif" size="3" color="#555555"><b>Room Type:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.room_type %></font></td>
          </tr>
          <tr>
            <td><font face="Arial, sans-serif" size="3" color="#555555"><b>Preferred Gender:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.gender %></font></td>
          </tr>
          <tr>
            <td><font face="Arial, sans-serif" size="3" color="#555555"><b>Roommates:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.roommates %></font></td>
          </tr>
          <tr>
            <td valign="top"><font face="Arial, sans-serif" size="3" color="#555555"><b>Description:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.description %></font></td>
          </tr>
          <% if (listing.amenities && listing.amenities.length > 0) { %>
          <tr>
            <td valign="top"><font face="Arial, sans-serif" size="3" color="#555555"><b>Amenities:</b></font></td>
            <td>
              <ul>
                <% listing.amenities.forEach(function(a) { %>
                  <li><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= a === 'ac' ? 'Air Condition' : a.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %></font></li>
                <% }) %>
              </ul>
            </td>
          </tr>
          <% } %>
          <tr>
            <td><font face="Arial, sans-serif" size="3" color="#555555"><b>Likes:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.likes.length %></font></td>
          </tr>
          <tr>
            <td><font face="Arial, sans-serif" size="3" color="#555555"><b>Comments:</b></font></td>
            <td><font face="Arial, sans-serif" size="3" color="#3a3a3a"><%= listing.comments.length %></font></td>
          </tr>
        </table>

        <br>

        <% if (user && listing.landlord && String(listing.landlord) === String(user.id)) { %>
          <a href="/listing/<%= listing._id %>/edit"><font face="Arial, sans-serif" size="3" color="#c0392b"><b>Edit Listing</b></font></a>
          <br>
        <% } %>

        <br>
        <hr color="#eeeeee" size="1">

        <font face="Georgia, serif" size="4" color="#3a3a3a"><b>Comments</b></font>
        <br><br>

        <% if (listing.comments.length === 0) { %>
          <font face="Arial, sans-serif" size="3" color="#777777">There are no comments.</font>
        <% } else { %>
          <% for (let j = 0; j < listing.comments.length; j++) { %>
            <% let comment = listing.comments[j]; %>
            <table border="0" cellpadding="10" cellspacing="0" bgcolor="#f7f4ef" width="100%" id="comment-<%= comment._id %>">
              <tr>
                <td>
                  <font face="Arial, sans-serif" size="3" color="#3a3a3a">
                    <b><%= comment.user ? comment.user.username : 'Unknown' %></b>
                  </font>
                  <font face="Arial, sans-serif" size="2" color="#999999">
                    &mdash; <%= new Date(comment.createdAt).toLocaleString() %>
                  </font>
                  <br>
                  <font face="Arial, sans-serif" size="3" color="#555555" id="comment-text-<%= comment._id %>"><%= comment.text %></font>
                  <% if (user && comment.user && comment.user._id.toString() === user.id.toString()) { %>
                    <br>
                    <font face="Arial, sans-serif" size="2">
                      <button onclick="editComment('<%= listing._id %>', '<%= comment._id %>')">Edit</button>
                      <button onclick="deleteComment('<%= listing._id %>', '<%= comment._id %>')">Delete</button>
                    </font>
                  <% } %>
                </td>
              </tr>
            </table>
            <br>
          <% } %>
        <% } %>
      </td>
    </tr>
  </table>

  <br><br>
  <font face="Arial, sans-serif" size="2" color="#aaaaaa">&copy; 2026 Roommie Finder</font>
  <br><br>
</center>

<script>
  async function addComment(listingId) {
    let input = document.getElementById('comment-input-' + listingId);
    let text = input.value.trim();
    if (!text) return;

    const res = await fetch('/explore/listings/' + listingId + '/comment', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text })
    });
    const data = await res.json();
    if (data.success) {
      location.reload();
    } else {
      alert(data.message);
    }
  }

  function editComment(listingId, commentId) {
    let textEl = document.getElementById('comment-text-' + commentId);
    let newText = prompt('Edit your comment:', textEl.textContent);
    if (newText === null || newText.trim() === '') return;

    fetch('/explore/listings/' + listingId + '/comments/' + commentId, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: newText.trim() })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        textEl.textContent = newText.trim();
      } else {
        alert(data.message);
      }
    });
  }

  async function deleteComment(listingId, commentId) {
    if (!confirm('Are you sure you want to delete this comment?')) return;

    const res = await fetch('/explore/listings/' + listingId + '/comments/' + commentId, {
      method: 'DELETE'
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById('comment-' + commentId).remove();
    } else {
      alert(data.message);
    }
  }
</script>

</body>
</html>
