<!DOCTYPE html>
<html>
<head>
  <title><%= listing.title %></title>
</head>
<body>

  <a href="/profile/<%= listing.landlord %>">Back to Profile</a>
  <br><br>

  <p><strong>Title:</strong> <%= listing.title %></p>
  <p><strong>Description:</strong> <%= listing.description %></p>
  <p><strong>Region:</strong> <%= listing.region %></p>
  <p><strong>Location:</strong> <%= listing.location %></p>
  <p><strong>Price:</strong> $<%= listing.price %> / month</p>
  <p><strong>Room Type:</strong> <%= listing.room_type %></p>
  <p><strong>Roommate Slots Available:</strong> <%= listing.roommates %></p>
  <p><strong>Owner Gender:</strong> <%= listing.my_gender %></p>

  <% if (listing.amenities.length > 0) { %>
    <p><strong>Amenities:</strong></p>
    <ul>
      <% listing.amenities.forEach(function(a) { %>
        <li><%= a.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %></li>
      <% }) %>
    </ul>
  <% } %>

  <% if (listing.photos.length > 0) { %>
    <p><strong>Photos:</strong></p>
    <% listing.photos.forEach(function(photo) { %>
      <img src="/uploads/<%= photo %>" width="300" height="300" alt="listing photo">
    <% }) %>
  <% } %>

  <br>

  <!-- Like Button -->
  <button id="like-btn-<%= listing._id %>" onclick="toggleLike('<%= listing._id %>')">
    <% if (user && listing.likes.some(id => id.toString() === user.id.toString())) { %>
      Unlike (<span id="like-count-<%= listing._id %>"><%= listing.likes.length %></span>)
    <% } else { %>
      Like (<span id="like-count-<%= listing._id %>"><%= listing.likes.length %></span>)
    <% } %>
  </button>

  <!-- Comment Button -->
  <button onclick="toggleComments('<%= listing._id %>')">
    Comments (<span id="comment-count-<%= listing._id %>"><%= listing.comments.length %></span>)
  </button>

  <!-- Wishlist Button -->
  <button id="wishlist-btn-<%= listing._id %>"
    <% if (isWishlisted) { %>disabled<% } %>
    onclick="toggleWishlist('<%= listing._id %>')">
    <%= isWishlisted ? 'Wishlisted' : 'Wishlist' %>
  </button>

  <!-- Comments Section (hidden by default) -->
  <div id="comments-<%= listing._id %>" style="margin-top:10px;">
    <h4>Comments</h4>
    <div id="comments-list-<%= listing._id %>">
      <% for (let j = 0; j < listing.comments.length; j++) { %>
        <% let comment = listing.comments[j]; %>
        <div id="comment-<%= comment._id %>" style="margin-bottom:8px; padding:5px; border-bottom:1px solid #ccc;">
          <strong><%= comment.user ? comment.user.username : 'Unknown' %></strong>
          <span style="font-size:0.8em; color:gray;">
            — <%= new Date(comment.createdAt).toLocaleString() %>
          </span>
          <p id="comment-text-<%= comment._id %>"><%= comment.text %></p>

          <% if (user && comment.user && comment.user._id.toString() === user.id.toString()) { %>
            <button onclick="editComment('<%= listing._id %>', '<%= comment._id %>')">Edit</button>
            <button onclick="deleteComment('<%= listing._id %>', '<%= comment._id %>')">Delete</button>
          <% } %>
        </div>
      <% } %>
    </div>

    <% if (user) { %>
      <textarea id="comment-input-<%= listing._id %>" placeholder="Write a comment..." rows="2" style="width:100%;"></textarea>
      <button onclick="addComment('<%= listing._id %>')">Submit Comment</button>
    <% } %>
  </div>

  <br><br>

  <% if (user && listing.landlord && String(listing.landlord) === String(user.id)) { %>
    <a href="/listing/<%= listing._id %>/edit">Edit Listing</a>
  <% } %>

  <script>
    async function toggleLike(listingId) {
      const res = await fetch('/explore/listings/' + listingId + '/like', { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        document.getElementById('like-count-' + listingId).textContent = data.likeCount;
        let btn = document.getElementById('like-btn-' + listingId);
        let countSpan = document.getElementById('like-count-' + listingId).outerHTML;
        btn.innerHTML = data.liked ? 'Unlike (' + countSpan + ')' : 'Like (' + countSpan + ')';
      } else {
        alert(data.message);
      }
    }

    function toggleComments(listingId) {
      let section = document.getElementById('comments-' + listingId);
      section.style.display = section.style.display === 'none' ? '' : 'none';
    }

    async function addComment(listingId) {
      let input = document.getElementById('comment-input-' + listingId);
      let text = input.value.trim();
      if (!text) return;

      const res = await fetch('/explore/listings/' + listingId + '/comment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });
      const data = await res.json();
      if (data.success) {
        location.reload();
      } else {
        alert(data.message);
      }
    }

    function editComment(listingId, commentId) {
      let textEl = document.getElementById('comment-text-' + commentId);
      let newText = prompt('Edit your comment:', textEl.textContent);
      if (newText === null || newText.trim() === '') return;

      fetch('/explore/listings/' + listingId + '/comments/' + commentId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: newText.trim() })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          textEl.textContent = newText.trim();
        } else {
          alert(data.message);
        }
      });
    }

    async function deleteComment(listingId, commentId) {
      if (!confirm('Are you sure you want to delete this comment?')) return;

      const res = await fetch('/explore/listings/' + listingId + '/comments/' + commentId, {
        method: 'DELETE'
      });
      const data = await res.json();
      if (data.success) {
        document.getElementById('comment-' + commentId).remove();
        let countEl = document.getElementById('comment-count-' + listingId);
        countEl.textContent = Number(countEl.textContent) - 1;
      } else {
        alert(data.message);
      }
    }

    async function toggleWishlist(listingId) {
      const res = await fetch('/wishlist/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ listingId })
      });
      if (res.ok) {
        let btn = document.getElementById('wishlist-btn-' + listingId);
        btn.textContent = 'Wishlisted';
        btn.disabled = true;
      } else {
        alert('Please login to add to wishlist');
      }
    }
  </script>

</body>
</html>
