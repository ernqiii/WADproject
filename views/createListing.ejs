<!DOCTYPE html>
<html>
<head>
  <title>Create Listing</title>
</head>

<body>

  <% if (error) { %>
  <p><%= error %></p>
  <% } %>
<h1>Create a New Room Listing</h1>

<form action="/listing" method="POST" enctype="multipart/form-data">

  <label for="title">Listing Title</label><br>
  <input 
    type="text" 
    id="title"
    name="title" 
    placeholder="Title" 
    maxlength="50"
    value="<%= data.title || '' %>" 
    required
  >
  <br><br>

  <label for="description">Description</label><br>
  <textarea 
    id="description"
    name="description" 
    rows="5" 
    cols="40" 
    placeholder="Room description"
    maxlength="200"
    required
  ><%= data.description || '' %></textarea></textarea>
  <br><br>

  <label for="region">Region</label><br>
  <select id="region" name="region" required>
    <option value="">Select a region</option>
  <option value="North"  <%= data.region === 'North'  ? 'selected' : '' %>>North</option>
  <option value="East"   <%= data.region === 'East'   ? 'selected' : '' %>>East</option>
  <option value="South"  <%= data.region === 'South'  ? 'selected' : '' %>>South</option>
  <option value="West"   <%= data.region === 'West'   ? 'selected' : '' %>>West</option>
  </select>
  <br><br>

  <label for="location">Location</label><br>
  <input 
    type="text" 
    id="location"
    name="location" 
    placeholder="Address"
    maxlength="50"
    value="<%= data.location || '' %>"
    required
  >
  <br><br>

  <label for="price">Price per Month ($)</label><br>
  <input 
    type="number" 
    id="price"
    name="price" 
    min="0"
    step="0.01"
    required
    value="<%= data.price || '' %>"
  >
  <br><br>

  <label for="roommates">Number of Roommates</label><br>
  <input 
    type="number" 
    id="roommates"
    name="roommates" 
    min="1"
    required
    value="<%= data.roommates || '' %>"
  >
  <br><br>

  <label for="room_type">Room Type</label><br>
  <select id="room_type" name="room_type" required>
    <option value="">Select a room type</option>
     <option value="Private Room"  <%= data.room_type === 'Private Room'  ? 'selected' : '' %>>Private Room</option>
  <option value="Shared Room"   <%= data.room_type === 'Shared Room'   ? 'selected' : '' %>>Shared Room</option>
  </select>
  <br><br>

  <label>Amenities</label><br>
  <input type="checkbox" id="wifi" name="amenities" value="wifi"
     <%- data.amenities && data.amenities.includes('wifi') ? 'checked' : '' %>>
  <label for="wifi">Wifi</label><br>

  <input type="checkbox" id="parking" name="amenities" value="parking"
    <%- data.amenities && data.amenities.includes('parking') ? 'checked' : '' %>>
  <label for="parking">Parking</label><br>

  <input type="checkbox" id="ac" name="amenities" value="ac"
  <%- data.amenities && data.amenities.includes('ac') ? 'checked' : '' %>>
  <label for="ac">Air Conditioning</label><br>
  <br>

  <label for="photos">Upload Photos (Max 3)</label><br>
  <input type="file" id="photos" name="photos" required multiple accept="image/*">
  <br><br>

  <button type="submit">Create Listing</button>
  <button type="reset">Clear</button>

</form>

</body>
</html>