<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Edit Profile</title>
</head>
<body bgcolor="#f7f4ef">
<center>
    <br>
    <font face="Georgia, serif" size="6" color="#3a3a3a"><b>🏠 Roommie Finder</b></font>
    <br>
    <font face="Arial, sans-serif" size="3" color="#555555">
        <a href="/explore"><font color="#c0392b">Explore</font></a> &nbsp;|&nbsp;
        <a href="/wishlist"><font color="#c0392b">Wishlist</font></a> &nbsp;|&nbsp;
        <a href="/listings"><font color="#c0392b">Listings</font></a> &nbsp;|&nbsp;
        <a href="/profile"><font color="#c0392b">Back to Profile</font></a>
    </font>
    <br><br>

    <table border="0" cellpadding="28" cellspacing="0" bgcolor="#ffffff" width="440">
        <tr>
            <td>
                <font face="Georgia, serif" size="5" color="#3a3a3a"><b>Edit Profile</b></font>
                <br><br>

                <% if (errorMessage) { %>
                    <table border="0" cellpadding="8" bgcolor="#fdecea" width="100%">
                        <tr>
                            <td>
                                <font face="Arial, sans-serif" size="2" color="#c0392b"><b><%= errorMessage %></b></font>
                            </td>
                        </tr>
                    </table>
                    <br>
                <% } %>

                <form method="POST" action="/profile/edit" enctype="multipart/form-data">
                    <table border="0" cellpadding="6" cellspacing="0" width="100%">
                        <tr>
                            <td width="140">
                                <font face="Arial, sans-serif" size="3" color="#555555"><b>Full Name:</b></font>
                            </td>
                            <td>
                                <input type="text" id="fullName" name="fullName" value="<%= user.fullName %>" required size="26">
                            </td>
                        </tr>
                        <tr><td colspan="2"><br></td></tr>
                        <tr>
                            <td>
                                <font face="Arial, sans-serif" size="3" color="#555555"><b>Email:</b></font>
                            </td>
                            <td>
                                <input type="email" id="email" name="email" value="<%= user.email %>" required size="26">
                            </td>
                        </tr>
                        <tr><td colspan="2"><br></td></tr>
                        <tr>
                            <td>
                                <font face="Arial, sans-serif" size="3" color="#555555"><b>Gender:</b></font>
                            </td>
                            <td>
                                <select id="gender" name="gender" required>
                                    <option value="Male" <%= user.gender === "Male" ? "selected" : "" %>>Male</option>
                                    <option value="Female" <%= user.gender === "Female" ? "selected" : "" %>>Female</option>
                                    <option value="Other" <%= user.gender === "Other" ? "selected" : "" %>>Other</option>
                                </select>
                            </td>
                        </tr>
                        <tr><td colspan="2"><br></td></tr>
                        <tr>
                            <td valign="top">
                                <font face="Arial, sans-serif" size="3" color="#555555"><b>Bio:</b></font>
                            </td>
                            <td>
                                <textarea id="bio" name="bio" rows="5" cols="26"><%= user.bio %></textarea>
                            </td>
                        </tr>
                        <tr><td colspan="2"><br></td></tr>
                        <tr>
                            <td valign="top">
                                <font face="Arial, sans-serif" size="3" color="#555555"><b>Profile Picture:</b></font>
                            </td>
                            <td>
                                <% if (user.profilePicture && user.profilePictureType) { %>
                                    <font face="Arial, sans-serif" size="2" color="#777777">Current:</font><br>
                                    <img src="data:<%= user.profilePictureType %>;base64,<%= user.profilePicture.toString('base64') %>"
                                         alt="Profile Picture" width="100" height="100">
                                    <br><br>
                                    <font face="Arial, sans-serif" size="2" color="#777777">Update (Max 2MB):</font><br>
                                    <input type="file" id="profilePicture" name="profilePicture" accept="image/*">
                                <% } else { %>
                                    <font face="Arial, sans-serif" size="2" color="#777777">Upload (Max 2MB):</font><br>
                                    <input type="file" id="profilePicture" name="profilePicture" accept="image/*" required>
                                <% } %>
                            </td>
                        </tr>
                    </table>

                    <br><br>
                    <center>
                        <table border="0" cellpadding="10" cellspacing="0" bgcolor="#c0392b" width="180">
                            <tr>
                                <td align="center">
                                    <input type="submit" value="Save Changes" style="background:transparent;border:none;color:#ffffff;font-size:14px;cursor:pointer;font-weight:bold;">
                                </td>
                            </tr>
                        </table>
                    </center>
                </form>
            </td>
        </tr>
    </table>

    <br><br>
    <font face="Arial, sans-serif" size="2" color="#aaaaaa">&copy; 2026 Roommie Finder</font>
    <br><br>
</center>
</body>
</html>
